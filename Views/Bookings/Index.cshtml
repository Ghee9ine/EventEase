@model IEnumerable<EventEase.Models.Booking>

<h2>All Bookings - Consolidated View</h2>

<form method="get" action="/Bookings/Search">
    <input type="text" name="searchTerm" placeholder="Search by Booking ID or Event Name" style="width: 300px;" />
    <button type="submit">Search</button>
</form>

<br />

<table border="1" cellpadding="8">
    <thead>
        <tr>
            <th>Booking ID</th>
            <th>Customer Name</th>
            <th>Customer Email</th>
            <th>Event Name</th>
            <th>Venue Name</th>
            <th>Event Date</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var booking in Model)
        {
            <tr>
                <td>@booking.BookingReference</td>
                <td>@booking.CustomerName</td>
                <td>@booking.CustomerEmail</td>
                <td>@(booking.Event?.Name ?? "N/A")</td>
                <td>@(booking.Event?.Venue?.Name ?? "N/A")</td>
                <td>@(booking.Event?.StartDate.ToShortDateString() ?? "N/A")</td>
                <td>@booking.Status</td>
                <td>
                    <a href="/Bookings/Cancel/@booking.BookingId" onclick="return confirm('Cancel this booking?')">Cancel</a>
                 </td>
            </tr>
        }
    </tbody>
</table>